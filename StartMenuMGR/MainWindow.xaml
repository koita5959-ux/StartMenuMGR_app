<Window x:Class="StartMenuMGR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:StartMenuMGR.Converters"
        Title="StartMenuMGR"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="700" Height="650"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibility"/>

        <!-- ダーク用スクロールバー Thumb -->
        <Style x:Key="DarkThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#555555" CornerRadius="4" Margin="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 縦スクロールバー -->
        <ControlTemplate x:Key="DarkVerticalScrollBar" TargetType="ScrollBar">
            <Grid Width="10">
                <Border Background="#1A1A1A" CornerRadius="4"/>
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.Thumb>
                        <Thumb Style="{StaticResource DarkThumb}"/>
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>

        <!-- 横スクロールバー -->
        <ControlTemplate x:Key="DarkHorizontalScrollBar" TargetType="ScrollBar">
            <Grid Height="10">
                <Border Background="#1A1A1A" CornerRadius="4"/>
                <Track x:Name="PART_Track">
                    <Track.Thumb>
                        <Thumb Style="{StaticResource DarkThumb}"/>
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>

        <!-- ツールバーボタン共通スタイル -->
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
            <Setter Property="Foreground" Value="#5BC0EB"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource ButtonHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- アクセントボタン -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ToolButton}">
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
            <Setter Property="Foreground" Value="#FF8FA0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- TreeView アイテムテンプレート -->
        <HierarchicalDataTemplate x:Key="EntryTemplate"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2,1">
                <!-- 通常項目: アイコン + 名前 -->
                <Image Source="{Binding Icon}" Width="16" Height="16"
                       Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock x:Name="EntryName" Text="{Binding Name}" VerticalAlignment="Center"
                           Foreground="{DynamicResource TreeTextForeground}"/>
            </StackPanel>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsGroupHeader}" Value="True">
                    <Setter TargetName="EntryName" Property="FontWeight" Value="Bold"/>
                    <Setter TargetName="EntryName" Property="Foreground" Value="{DynamicResource TreeHeaderText}"/>
                    <Setter TargetName="EntryName" Property="Margin" Value="0,6,0,2"/>
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid Background="{DynamicResource WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ツールバー -->
        <Border Grid.Row="0" Padding="8,6"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="StartMenuMGR" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextForeground}"
                           VerticalAlignment="Center" Margin="4,0,16,0"/>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                            HorizontalAlignment="Right">
                    <Button Content="更新" Command="{Binding RefreshCommand}"
                            Style="{DynamicResource ToolButton}" Margin="0,0,4,0"/>
                    <Button Content="適用" Command="{Binding ApplyCommand}"
                            Style="{DynamicResource AccentButton}" Margin="0,0,4,0"/>
                    <Button Content="元に戻す" Command="{Binding RestoreCommand}"
                            Style="{DynamicResource ToolButton}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- メインコンテンツ -->
        <Grid Grid.Row="1" Margin="8,8,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 上段: ツリー | アイコンエリア -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" MinWidth="180"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左: 疑似スタートメニュー ツリー -->
                <Border Grid.Column="0" CornerRadius="4"
                        Background="{DynamicResource TreePanelBackground}"
                        BorderBrush="{DynamicResource TreePanelBorder}"
                        BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="スタートメニュー" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TreeTextForeground}"
                                   Margin="10,8,10,6" FontSize="13"/>
                        <TreeView x:Name="MenuTree"
                                  ItemsSource="{Binding Entries}"
                                  ItemTemplate="{StaticResource EntryTemplate}"
                                  SelectedItemChanged="MenuTree_SelectedItemChanged"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Padding="4"
                                  VirtualizingStackPanel.IsVirtualizing="True">
                            <TreeView.Resources>
                                <Style TargetType="ScrollBar">
                                    <Style.Triggers>
                                        <Trigger Property="Orientation" Value="Vertical">
                                            <Setter Property="Template" Value="{StaticResource DarkVerticalScrollBar}"/>
                                        </Trigger>
                                        <Trigger Property="Orientation" Value="Horizontal">
                                            <Setter Property="Template" Value="{StaticResource DarkHorizontalScrollBar}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TreeView.Resources>
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TreeTextForeground}"/>
                                    <Setter Property="Padding" Value="2,1"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TreeViewItem">
                                                <StackPanel>
                                                    <Border x:Name="ItemBorder" Background="Transparent"
                                                            Padding="4,3" CornerRadius="3"
                                                            MouseLeftButtonUp="TreeItem_MouseLeftButtonUp">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ContentPresenter x:Name="PART_Header" ContentSource="Header"
                                                                              Grid.Column="0" VerticalAlignment="Center"/>
                                                            <TextBlock x:Name="Chevron" Grid.Column="1"
                                                                       Text="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="10" Foreground="#888888"
                                                                       VerticalAlignment="Center" Margin="8,0,4,0"
                                                                       Visibility="Collapsed"/>
                                                        </Grid>
                                                    </Border>
                                                    <ItemsPresenter x:Name="ItemsHost" Margin="16,0,0,0"
                                                                    Visibility="Collapsed"/>
                                                </StackPanel>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="HasItems" Value="True">
                                                        <Setter TargetName="Chevron" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                    <Trigger Property="IsExpanded" Value="True">
                                                        <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="Chevron" Property="Text" Value="&#xE70D;"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#333333"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background"
                                                                Value="{DynamicResource TreeItemSelected}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>
                    </DockPanel>
                </Border>

                <!-- スプリッター -->
                <GridSplitter Grid.Column="1" Width="4"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"/>

                <!-- 右: アイコングリッドエリア -->
                <Border Grid.Column="2" CornerRadius="4"
                        Background="{DynamicResource TreePanelBackground}"
                        BorderBrush="{DynamicResource TreePanelBorder}"
                        BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar">
                                <Style.Triggers>
                                    <Trigger Property="Orientation" Value="Vertical">
                                        <Setter Property="Template" Value="{StaticResource DarkVerticalScrollBar}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Resources>
                        <ItemsControl ItemsSource="{Binding IconItems}" Margin="8,6">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent" CornerRadius="3"
                                            Padding="2" Margin="1" Width="60" Height="58"
                                            ToolTip="{Binding Name}"
                                            MouseLeftButtonUp="IconItem_Click">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Image Source="{Binding Icon}" Width="24" Height="24"
                                                   HorizontalAlignment="Center"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{DynamicResource TreeTextForeground}"
                                                       FontSize="9" TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxHeight="24" Margin="0,2,0,0"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- 下段: 詳細情報パネル（全幅） -->
        <Border Grid.Row="1" Margin="0,4,0,0"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1,1,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
                <StackPanel x:Name="DetailPanel" Margin="12,8">
                    <!-- 選択なし -->
                    <StackPanel x:Name="NoSelectionText">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{DynamicResource TextForeground}"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding TotalItems, StringFormat='合計 {0} 項目を管理中'}"
                                   Foreground="{DynamicResource SecondaryTextForeground}"
                                   FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- 選択あり -->
                    <StackPanel x:Name="DetailContent" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- アイコン大 -->
                            <Image Source="{Binding SelectedEntry.Icon}"
                                   Width="48" Height="48" Margin="0,0,16,0"
                                   VerticalAlignment="Top"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                            <!-- 詳細情報 -->
                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 名前 -->
                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                           Text="{Binding SelectedEntry.Name}"
                                           Foreground="{DynamicResource TextForeground}"
                                           FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>

                                <!-- 種類 -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="種類:"
                                           Foreground="{DynamicResource SecondaryTextForeground}"
                                           FontSize="11" Margin="0,2,12,0"/>
                                <TextBlock x:Name="TypeText" Grid.Row="1" Grid.Column="1"
                                           Foreground="{DynamicResource TextForeground}" FontSize="11"
                                           Margin="0,2,0,0"/>

                                <!-- スコープ -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="スコープ:"
                                           Foreground="{DynamicResource SecondaryTextForeground}"
                                           FontSize="11" Margin="0,2,12,0"/>
                                <TextBlock x:Name="ScopeText" Grid.Row="2" Grid.Column="1"
                                           Foreground="{DynamicResource TextForeground}" FontSize="11"
                                           Margin="0,2,0,0"/>

                                <!-- パス -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="パス:"
                                           Foreground="{DynamicResource SecondaryTextForeground}"
                                           FontSize="11" Margin="0,2,12,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1"
                                           Text="{Binding SelectedEntry.FullPath}"
                                           Foreground="{DynamicResource TextForeground}"
                                           TextWrapping="Wrap" FontSize="11" Margin="0,2,0,0"/>

                                <!-- リンク先 -->
                                <TextBlock x:Name="TargetPathLabel" Grid.Row="4" Grid.Column="0"
                                           Text="リンク先:"
                                           Foreground="{DynamicResource SecondaryTextForeground}"
                                           FontSize="11" Margin="0,2,12,0" Visibility="Collapsed"/>
                                <TextBlock x:Name="TargetPathText" Grid.Row="4" Grid.Column="1"
                                           Text="{Binding SelectedEntry.TargetPath}"
                                           Foreground="{DynamicResource TextForeground}"
                                           TextWrapping="Wrap" FontSize="11" Margin="0,2,0,0"
                                           Visibility="Collapsed"/>

                                <!-- リンク先状態 -->
                                <TextBlock x:Name="TargetStatusLabel" Grid.Row="5" Grid.Column="0"
                                           Text="状態:"
                                           Foreground="{DynamicResource SecondaryTextForeground}"
                                           FontSize="11" Margin="0,2,12,0" Visibility="Collapsed"/>
                                <TextBlock x:Name="TargetStatusText" Grid.Row="5" Grid.Column="1"
                                           Foreground="{DynamicResource TextForeground}" FontSize="11"
                                           Margin="0,2,0,0" Visibility="Collapsed"/>

                                <!-- 更新日時 -->
                                <TextBlock x:Name="ModifiedLabel" Grid.Row="6" Grid.Column="0"
                                           Text="更新日時:"
                                           Foreground="{DynamicResource SecondaryTextForeground}"
                                           FontSize="11" Margin="0,2,12,0" Visibility="Collapsed"/>
                                <TextBlock x:Name="ModifiedText" Grid.Row="6" Grid.Column="1"
                                           Foreground="{DynamicResource TextForeground}" FontSize="11"
                                           Margin="0,2,0,0" Visibility="Collapsed"/>

                                <!-- 引数 -->
                                <TextBlock x:Name="ArgsLabel" Grid.Row="7" Grid.Column="0"
                                           Text="引数:"
                                           Foreground="{DynamicResource SecondaryTextForeground}"
                                           FontSize="11" Margin="0,2,12,0" Visibility="Collapsed"/>
                                <TextBlock x:Name="ArgsText" Grid.Row="7" Grid.Column="1"
                                           Foreground="{DynamicResource TextForeground}"
                                           TextWrapping="Wrap" FontSize="11" Margin="0,2,0,0"
                                           Visibility="Collapsed"/>

                                <!-- 作業フォルダ -->
                                <TextBlock x:Name="WorkDirLabel" Grid.Row="8" Grid.Column="0"
                                           Text="作業フォルダ:"
                                           Foreground="{DynamicResource SecondaryTextForeground}"
                                           FontSize="11" Margin="0,2,12,0" Visibility="Collapsed"/>
                                <TextBlock x:Name="WorkDirText" Grid.Row="8" Grid.Column="1"
                                           Foreground="{DynamicResource TextForeground}"
                                           TextWrapping="Wrap" FontSize="11" Margin="0,2,0,0"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
            </Border>
        </Grid>

        <!-- ステータスバー -->
        <Border Grid.Row="2" VerticalAlignment="Bottom" Padding="10,3"
                Background="Transparent">
            <TextBlock Text="{Binding TotalItems, StringFormat='{}{0} 項目'}"
                       Foreground="{DynamicResource SecondaryTextForeground}"
                       FontSize="10" HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</Window>
