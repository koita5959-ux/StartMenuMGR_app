<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>..\Assets\app.ico</ApplicationIcon>
    <AssemblyTitle>StartMenuMGR</AssemblyTitle>
    <Description>Windows 10 Start Menu Manager</Description>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="..\Assets\app.ico" Link="Assets\app.ico" />
  </ItemGroup>

</Project>
