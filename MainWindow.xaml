<Window x:Class="StartMenuMGR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:StartMenuMGR.Converters"
        Title="StartMenuMGR"
        Icon="Assets/app.ico"
        Width="900" Height="650"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibility"/>

        <!-- ツールバーボタン共通スタイル -->
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource ButtonHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- アクセントボタン -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ToolButton}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- TreeView アイテムテンプレート -->
        <HierarchicalDataTemplate x:Key="EntryTemplate"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2,1">
                <Image Source="{Binding Icon}" Width="16" Height="16"
                       Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextForeground}"/>
            </StackPanel>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid Background="{DynamicResource WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ツールバー -->
        <Border Grid.Row="0" Padding="8,6"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="StartMenuMGR" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextForeground}"
                           VerticalAlignment="Center" Margin="4,0,16,0"/>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                            HorizontalAlignment="Right">
                    <Button Content="更新" Command="{Binding RefreshCommand}"
                            Style="{DynamicResource ToolButton}" Margin="0,0,4,0"/>
                    <Button Content="適用" Command="{Binding ApplyCommand}"
                            Style="{DynamicResource AccentButton}" Margin="0,0,4,0"/>
                    <Button Content="元に戻す" Command="{Binding RestoreCommand}"
                            Style="{DynamicResource ToolButton}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- メインコンテンツ -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="250"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- 疑似スタートメニュー ツリー -->
            <Border Grid.Column="0" CornerRadius="4"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="スタートメニュー" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextForeground}"
                               Margin="10,8,10,6" FontSize="13"/>
                    <TreeView x:Name="MenuTree"
                              ItemsSource="{Binding Entries}"
                              ItemTemplate="{StaticResource EntryTemplate}"
                              SelectedItemChanged="MenuTree_SelectedItemChanged"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="4"
                              VirtualizingStackPanel.IsVirtualizing="True">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
                                <Setter Property="Padding" Value="2,1"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- スプリッター -->
            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"/>

            <!-- 詳細パネル -->
            <Border Grid.Column="2" CornerRadius="4"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="詳細" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextForeground}"
                               Margin="10,8,10,6" FontSize="13"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10,4" x:Name="DetailPanel">
                            <!-- 選択なし -->
                            <TextBlock x:Name="NoSelectionText"
                                       Text="項目を選択してください"
                                       Foreground="{DynamicResource SecondaryTextForeground}"
                                       FontSize="12"/>

                            <!-- 選択あり -->
                            <StackPanel x:Name="DetailContent" Visibility="Collapsed">
                                <Image Source="{Binding SelectedEntry.Icon}"
                                       Width="48" Height="48" Margin="0,4,0,8"
                                       HorizontalAlignment="Left"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>

                                <TextBlock Text="名前" FontWeight="SemiBold" FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextForeground}" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding SelectedEntry.Name}"
                                           Foreground="{DynamicResource TextForeground}"
                                           TextWrapping="Wrap" FontSize="13"/>

                                <TextBlock Text="種類" FontWeight="SemiBold" FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextForeground}" Margin="0,10,0,2"/>
                                <TextBlock x:Name="TypeText"
                                           Foreground="{DynamicResource TextForeground}" FontSize="12"/>

                                <TextBlock Text="スコープ" FontWeight="SemiBold" FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextForeground}" Margin="0,10,0,2"/>
                                <TextBlock x:Name="ScopeText"
                                           Foreground="{DynamicResource TextForeground}" FontSize="12"/>

                                <TextBlock Text="パス" FontWeight="SemiBold" FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextForeground}" Margin="0,10,0,2"/>
                                <TextBlock Text="{Binding SelectedEntry.FullPath}"
                                           Foreground="{DynamicResource TextForeground}"
                                           TextWrapping="Wrap" FontSize="11"/>

                                <StackPanel x:Name="TargetPathPanel" Visibility="Collapsed">
                                    <TextBlock Text="リンク先" FontWeight="SemiBold" FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextForeground}" Margin="0,10,0,2"/>
                                    <TextBlock Text="{Binding SelectedEntry.TargetPath}"
                                               Foreground="{DynamicResource TextForeground}"
                                               TextWrapping="Wrap" FontSize="11"/>
                                </StackPanel>

                                <StackPanel x:Name="DescriptionPanel" Visibility="Collapsed">
                                    <TextBlock Text="説明" FontWeight="SemiBold" FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextForeground}" Margin="0,10,0,2"/>
                                    <TextBlock Text="{Binding SelectedEntry.Description}"
                                               Foreground="{DynamicResource TextForeground}"
                                               TextWrapping="Wrap" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ステータスバー -->
        <Border Grid.Row="2" Padding="10,5"
                Background="{DynamicResource StatusBarBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock Text="{Binding TotalItems, StringFormat='{}{0} 項目'}"
                           DockPanel.Dock="Right"
                           Foreground="{DynamicResource SecondaryTextForeground}"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource TextForeground}"
                           FontSize="11" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
